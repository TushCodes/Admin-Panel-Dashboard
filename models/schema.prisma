generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model Consignment {
  consignmentNum String    @id @map("consignment_num") @db.VarChar(16)
  status         String?   @db.VarChar(50)
  pickupAddress  String?   @map("pickup_address") @db.Text
  pickupPincode  String?   @map("pickup_pincode") @db.VarChar(20)
  pickupTag      String?   @map("pickup_tag") @db.VarChar(100)
  pickupDate     DateTime? @map("pickup_date") @db.Date
  dropAddress    String?   @map("drop_address") @db.Text
  dropPincode    String?   @map("drop_pincode") @db.VarChar(20)
  dropTag        String?   @map("drop_tag") @db.VarChar(100)
  dropDate       DateTime? @map("drop_date") @db.Date

  @@index([pickupPincode])
  @@index([dropPincode])
  @@map("consignments")
}

model Document {
  id             Int    @id @default(autoincrement())
  documentUpload String @map("document_upload") @db.Text

  @@map("documents")
}

model Lead {
  id      Int     @id @default(autoincrement())
  name    String  @db.VarChar(255)
  email   String? @db.VarChar(255)
  phone   String  @db.VarChar(30)
  subject String? @db.VarChar(255)
  message String? @db.Text

  @@index([email])
  @@index([phone])
  @@map("leads")
}


model DashboardMetric {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(255)
  value    Decimal   @db.Decimal(18, 2)
  period   DateTime? @db.Date
  metadata Json      @default("{}")

  @@index([name])
  @@map("dashboard_metrics")
}
