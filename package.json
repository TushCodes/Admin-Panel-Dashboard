{
  "name": "admin-panel-dashboard",
  "version": "1.0.0",
  "description": "JavaScript foundation for the Admin Panel Dashboard.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "frontend": "node frontend/serve.js",
    "build:css": "node scripts/build-tailwind.mjs",
    "dev:frontend": "vite --host 127.0.0.1",
    "build:frontend": "npm run build:css && vite build && node scripts/copy-frontend-assets.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^5.2.1",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "pg": "^8.16.3",
    "morgan": "^1.10.1",
    "zod": "^4.1.13",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "prisma": "^7.0.0",
    "dotenv": "^17.2.3",
    "vite": "^6.0.0"
  }
}
