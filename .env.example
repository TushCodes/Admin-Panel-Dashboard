# Copy this file to .env locally or set these values in your deployment secret store.
# Never commit real database URLs, passwords, or application secret keys.

# PostgreSQL connection string used by Prisma/Express when database-backed routes are enabled.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Application secret used to enable the production database path.
SECRET_KEY="replace-me"
