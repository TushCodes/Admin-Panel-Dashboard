# Copy this file to .env locally or set these values in your deployment secret store.
# Never commit real database URLs, passwords, JWT secrets, or service-role keys.

# Supabase PostgreSQL connection string used by Prisma/Express.
DATABASE_URL="postgresql://postgres.<project-ref>:<database-password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Application secret used to enable the production database path.
SECRET_KEY="replace-with-a-long-random-secret"

# Optional public frontend defaults for the dummy Supabase Auth UI.
# The project URL can usually be derived from the project ref: https://<project-ref>.supabase.co
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="paste-public-anon-key-here"
